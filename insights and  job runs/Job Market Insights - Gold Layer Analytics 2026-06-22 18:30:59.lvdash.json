{
  "datasets": [
    {
      "name": "job_market_metrics",
      "displayName": "Job Market Metrics",
      "config": {
        "source": "muse.gold.job_muse_gold_main",
        "measures": [
          {
            "displayName": "Total Jobs",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "total_jobs",
            "expr": "COUNT(*)",
            "comment": "Total number of job postings"
          },
          {
            "displayName": "Unique Companies",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "unique_companies",
            "expr": "COUNT(DISTINCT company_id)",
            "comment": "Number of unique companies hiring"
          }
        ],
        "version": "1.1",
        "comment": "Centralized metrics for job market analysis from the gold layer",
        "dimensions": [
          {
            "name": "company_name",
            "expr": "company_name",
            "displayName": "Company Name",
            "comment": "Name of the hiring company"
          },
          {
            "name": "exp_level",
            "expr": "exp_level",
            "displayName": "Experience Level",
            "comment": "Required experience level for the job"
          },
          {
            "name": "mode_of_work",
            "expr": "mode_of_work",
            "displayName": "Work Mode",
            "comment": "Remote, hybrid, or on-site work mode"
          },
          {
            "name": "location_city",
            "expr": "`location-city`",
            "displayName": "City",
            "comment": "Job location city"
          },
          {
            "name": "location_state",
            "expr": "`location-state`",
            "displayName": "State",
            "comment": "Job location state"
          },
          {
            "name": "job_type",
            "expr": "type",
            "displayName": "Job Type",
            "comment": "Type of employment"
          },
          {
            "name": "publication_month",
            "expr": "DATE_TRUNC('MONTH', publication_date)",
            "displayName": "Publication Month",
            "comment": "Month when the job was published"
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "ae816039",
      "displayName": "Untitled page",
      "layout": [
        {
          "widget": {
            "name": "total_jobs_counter",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "job_market_metrics",
                  "fields": [
                    {
                      "name": "measure(total_jobs)",
                      "expression": "MEASURE(`total_jobs`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Total Job Postings",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "measure(total_jobs)"
                }
              },
              "data": {
                "queryName": "main_query"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
